# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
# Secret used by Better Auth
BETTER_AUTH_SECRET=""

# Shared secret a new user must enter on the sign-up form to create an account.
# If left empty, account creation is disabled (no key can match).
REGISTRATION_KEY=""

# Database
# Local development: point at a local SQLite file.
DATABASE_URL="file:./db.sqlite"
# Production (Turso): when set, takes precedence over DATABASE_URL.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# S3 (used for image uploads from the admin editor). The region/credentials may
# instead be supplied with the conventional AWS_* names (AWS_REGION,
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY); the S3_* names take precedence.
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Origin that serves migrated images. Leave empty in dev to load from
# /public/uploads/ on disk. In production set to your S3 / CloudFront URL,
# e.g. "https://gms-images.s3.amazonaws.com" or "https://cdn.example.com".
NEXT_PUBLIC_UPLOADS_BASE_URL=""

# Public origin of the site. Used as the Akismet `blog` parameter and for
# building comment permalinks, e.g. "https://goodmorningshelly.com".
NEXT_PUBLIC_SITE_URL=""

# --- Comment spam / bot filtering ---
# All optional: when a key is unset, that check is skipped (fails open), so
# local development works without any of them.

# Cloudflare Turnstile (invisible CAPTCHA on the comment form). Create a widget
# at https://dash.cloudflare.com/?to=/:account/turnstile to get the keys.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Akismet content spam classification. Get a key at https://akismet.com/.
AKISMET_API_KEY=""

# --- Social login (Better Auth) ---
# A provider is enabled only when both its id and secret are set.
# Google: https://console.cloud.google.com/apis/credentials
# Redirect URI: <site>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Facebook: https://developers.facebook.com/apps/
# Redirect URI: <site>/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
